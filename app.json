{
  "expo": {
    "name": "training-app",
    "slug": "training-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "training-app",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.josemonrealbadia.trainingapp"
    },
    "android": {
      "package": "com.josemonrealbadia.trainingapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-status-bar"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ecac33b0-8aaa-4549-b90b-729d1ea12c15"
      }
    }
  }
}
